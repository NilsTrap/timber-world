# Copy to .env.local and fill in real values from the staging Supabase project.
# .env.local is gitignored.

TEST_SUPABASE_URL=https://YOUR-STAGING-REF.supabase.co
TEST_SUPABASE_ANON_KEY=...
TEST_SUPABASE_SERVICE_ROLE_KEY=...

# Optional
# TEST_ENV=staging
# NEGATIVE_TESTS_FAIL_ON_LEAK=true   # set to true once RLS is in place
